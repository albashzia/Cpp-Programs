{
  "code-runner.executorMap": {
    "cpp": "if (!(Test-Path \"${workspaceFolder}\\build\\bin\")) { New-Item -ItemType Directory -Path \"${workspaceFolder}\\build\\bin\" }; g++ \"$fullFileName\" -o \"${workspaceFolder}\\build\\bin\\$fileNameWithoutExt.exe\"; & \"${workspaceFolder}\\build\\bin\\$fileNameWithoutExt.exe\""
  },
  "code-runner.runInTerminal": true
}
